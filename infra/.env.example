# Copie este arquivo para ".env" (na mesma pasta infra/) se quiser mudar
# portas ou credenciais. Sem esse arquivo, o docker-compose.yml usa os
# valores default indicados abaixo.

# --- Postgres: event store (records-command-service) ---
POSTGRES_COMMAND_DB=records_command
POSTGRES_COMMAND_USER=command_service
POSTGRES_COMMAND_PASSWORD=command_service
POSTGRES_COMMAND_PORT=5432

# --- Postgres: read models (records-query-service) ---
POSTGRES_QUERY_DB=records_query
POSTGRES_QUERY_USER=query_service
POSTGRES_QUERY_PASSWORD=query_service
POSTGRES_QUERY_PORT=5433

# --- Postgres: audit log (audit-service) ---
POSTGRES_AUDIT_DB=audit
POSTGRES_AUDIT_USER=audit_service
POSTGRES_AUDIT_PASSWORD=audit_service
POSTGRES_AUDIT_PORT=5434

# --- Redpanda (broker de eventos compativel com Kafka) ---
REDPANDA_KAFKA_PORT=19092
REDPANDA_SCHEMA_REGISTRY_PORT=18081
REDPANDA_PANDAPROXY_PORT=18082
REDPANDA_ADMIN_PORT=19644
REDPANDA_CONSOLE_PORT=8080
